{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document containing role and other details",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the user"
        },
        "email": {
          "type": "string",
          "description": "Email address of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when user was created"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "Role of the user"
        }
      },
      "required": ["name", "email", "createdAt", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory product details",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Product name"
        },
        "sku": {
          "type": "string",
          "description": "Auto-generated SKU"
        },
        "category": {
          "type": "string",
          "description": "Product category name"
        },
        "description": {
          "type": "string",
          "description": "Product description"
        },
        "quantity": {
          "type": "number",
          "description": "Current quantity in stock"
        },
        "minStock": {
          "type": "number",
          "description": "Minimum stock replenishment threshold"
        },
        "price": {
          "type": "number",
          "description": "Unit price of the product"
        },
        "supplier": {
          "type": "string",
          "description": "Supplier name"
        },
        "imageUrl": {
          "type": "string",
          "description": "Optional product image URL"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last updated timestamp"
        },
        "userId": {
          "type": "string",
          "description": "User ID of the inventory owner"
        }
      },
      "required": ["name", "sku", "category", "description", "quantity", "minStock", "price", "supplier", "createdAt", "updatedAt", "userId"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category definition",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Category name"
        },
        "color": {
          "type": "string",
          "description": "Hex color code for the category"
        },
        "userId": {
          "type": "string",
          "description": "User ID of the category owner"
        }
      },
      "required": ["name", "color", "userId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Inventory stock movement transaction",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string",
          "description": "Associated product ID"
        },
        "productName": {
          "type": "string",
          "description": "Display name of the product at transaction time"
        },
        "type": {
          "type": "string",
          "enum": ["entrée", "sortie", "ajustement"],
          "description": "Type of movement"
        },
        "quantity": {
          "type": "number",
          "description": "Quantity changed (positive value)"
        },
        "note": {
          "type": "string",
          "description": "Optional transaction note"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Date of the transaction"
        },
        "userId": {
          "type": "string",
          "description": "User ID of the transaction author"
        }
      },
      "required": ["productId", "productName", "type", "quantity", "note", "date", "userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of inventory products"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories"
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of inventory stock transactions"
    }
  }
}
